# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# Isaac Sim / Omniverse local caches (never commit these)
*.usd.bak
kit_cache/
.nvidia-omniverse/
.thumbs/

# Vendored third-party asset packs, hand-authored scenes, and vendor CAD
# source were previously excluded here (too large for plain git, and of
# uncertain redistribution rights). Now tracked via Git LFS instead --
# see .gitattributes. Each directory's own SOURCE.md still documents
# provenance / how to re-fetch if needed.

# Session screen recordings -- debugging artifacts, never meant to be committed.
*.webm

# Docker container.py runtime state
docker/.container.cfg
docker/.isaac-cobot-docker-history

# Session scratch output -- never meant to be committed
scratchpad/*

# Editors / OS
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db

# Secrets - never commit tokens or env overrides
.env
.env.local
*.token
