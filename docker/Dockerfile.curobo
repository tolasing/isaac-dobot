# Adds cuRobo (pinned commit) on top of isaac-cobot-base.
# build-essential/cmake/git are already present in isaac-cobot-base.
#
# Originally built and smoke-tested (torch + curobo import, CUDA available,
# tensors on GPU) against a live RTX PRO 4000 Blackwell (sm_120).
#
# This project's actual cloud GPU assignment has changed three times across
# sessions on the `dobot` branch -- Blackwell workstation, then an NVIDIA L4
# (Ada Lovelace, sm_89), now an NVIDIA RTX A6000 (Ampere, sm_86, confirmed
# via `nvidia-smi --query-gpu=name,compute_cap`). See TORCH_CUDA_ARCH_LIST's
# own comment below for how that's now handled.

ARG DOCKER_NAME_SUFFIX=""
FROM isaac-cobot-base${DOCKER_NAME_SUFFIX} AS curobo

USER root

# Detect Ubuntu version and install CUDA 12.8 via NVIDIA's network repo
# (cuda-keyring). cuRobo compiles CUDA kernels at install time
# (--no-build-isolation below), which needs nvcc present in the image.
# ninja-build is for a separate, later need: if a prebuilt cuRobo kernel
# (e.g. kinematics_fused_cu) has a torch ABI mismatch at *runtime*, cuRobo
# falls back to JIT-compiling it via torch's cpp_extension.load(), which
# requires ninja on PATH -- confirmed missing and required live (see
# CLAUDE.md). Not `pip install ninja`: pip itself is broken in this Isaac
# Sim install (`ModuleNotFoundError: No module named
# 'pip._vendor.packaging._structures'`).
RUN set -euo pipefail && \
    . /etc/os-release && \
    case "$ID" in \
      ubuntu) \
        case "$VERSION_ID" in \
          "20.04") cuda_repo="ubuntu2004";; \
          "22.04") cuda_repo="ubuntu2204";; \
          "24.04") cuda_repo="ubuntu2404";; \
          *) echo "Unsupported Ubuntu $VERSION_ID"; exit 1;; \
        esac ;; \
      *) echo "Unsupported base OS: $ID"; exit 1 ;; \
    esac && \
    apt-get update && apt-get install -y --no-install-recommends wget gnupg ca-certificates && \
    wget -q https://developer.download.nvidia.com/compute/cuda/repos/${cuda_repo}/x86_64/cuda-keyring_1.1-1_all.deb && \
    dpkg -i cuda-keyring_1.1-1_all.deb && \
    rm -f cuda-keyring_1.1-1_all.deb && \
    wget -q https://developer.download.nvidia.com/compute/cuda/repos/${cuda_repo}/x86_64/cuda-${cuda_repo}.pin && \
    mv cuda-${cuda_repo}.pin /etc/apt/preferences.d/cuda-repository-pin-600 && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        cuda-toolkit-12-8 \
        libcudnn9-cuda-12 \
        libcusparselt0 \
        libnccl2 \
        libnccl-dev \
        libnvjitlink-12-8 \
        ninja-build && \
    apt-get -y autoremove && apt-get clean && rm -rf /var/lib/apt/lists/*

ENV CUDA_HOME=/usr/local/cuda-12.8
ENV PATH=${CUDA_HOME}/bin:${PATH}
ENV LD_LIBRARY_PATH=${CUDA_HOME}/lib64:${LD_LIBRARY_PATH}
# cuRobo's own custom CUDA kernels (kinematics_fused_cu etc.) are
# architecture-locked to whatever TORCH_CUDA_ARCH_LIST is set to here at
# `pip install` time -- confirmed live that an sm_89-only build fails on
# an sm_86 card with `torch.AcceleratorError: CUDA error: no kernel image
# is available for execution on the device` (PTX compatibility is
# forward-only: sm_89 code doesn't run on sm_86, which is lower, only the
# reverse). Rather than re-tuning this single-arch value and rebuilding
# again on a fourth cloud GPU swap, this now targets all three
# architectures actually seen so far in one fat binary -- costs extra
# nvcc compile time during this Dockerfile's build, not runtime. +PTX only
# on the newest (Blackwell) entry, for forward-JIT compatibility with
# anything newer than that. Covers: Ampere/RTX A6000 (8.6), Ada/L4 (8.9),
# Blackwell/RTX PRO 4000 (12.0).
ENV TORCH_CUDA_ARCH_LIST="8.6;8.9;12.0+PTX"

# Isaac Sim ships its own torch under omni.isaac.ml_archive/pip_prebundle/,
# which python.sh's sys.path resolves BEFORE site-packages. Left in place,
# `import torch` picks up that bundled copy instead of the one installed
# below, and crashes on a vendored-packaging submodule mismatch between the
# two (found by actually running this image against a live GPU).
RUN rm -rf ${ISAACSIM_ROOT_PATH}/exts/omni.isaac.ml_archive/pip_prebundle/torch*

# Install a CUDA-12.8-matched torch build. cuRobo needs torch present
# before its own install step below.
RUN --mount=type=cache,target=${DOCKER_USER_HOME}/.cache/pip \
    ${ISAACSIM_ROOT_PATH}/python.sh -m pip install torch --index-url https://download.pytorch.org/whl/cu128

# Install cuRobo from source, pinned to the commit recorded in .env.curobo.
ARG CUROBO_COMMIT_ARG
RUN --mount=type=cache,target=${DOCKER_USER_HOME}/.cache/pip \
    ${ISAACSIM_ROOT_PATH}/python.sh -m pip install --no-build-isolation \
    "nvidia-curobo @ git+https://github.com/NVlabs/curobo.git@${CUROBO_COMMIT_ARG}"

WORKDIR ${DOCKER_ISAAC_COBOT_PATH}
